# OS
.DS_Store
Thumbs.db

# Env / secrets
.env
.env.*
!.env.example

# Editor
.idea/
.vscode/
*.swp

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Node
node_modules/
dist/
build/

# Logs
*.log

# Generated media — keep metadata sidecars (.md/.json) and .gitkeep, ignore binaries
outputs/**/*.png
outputs/**/*.jpg
outputs/**/*.jpeg
outputs/**/*.webp
outputs/**/*.gif
outputs/**/*.mp4
outputs/**/*.mov

# Reference material from others' accounts — keep manifests/notes, ignore image binaries (private, IP)
references/**/*.png
references/**/*.jpg
references/**/*.jpeg
references/**/*.webp
references/**/*.mp4

# Automation: local account config (non-secret but account-specific) — ship config.example.yml
automation/config.yml

# Automation: generated feed-grid preview (build artifact; regenerate via feed_preview.py)
automation/feed-preview.html

# Generated candidate contact-sheet (build artifact; regenerate via contact_sheet.py)
outputs/**/contact-sheet.html

# Feed Studio local selects arrangement (planning state, machine-local)
outputs/selects/.order.json

# Automation: staged source video — keep sidecars (uploaded.json) + cover image, ignore the heavy
# video binary itself (hosted on Cloudflare R2, not committed). See asset-queue-model.md §2/§10.
automation/video/**/*.mp4
automation/video/**/*.mov
